# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# Zerion API key — get from https://developers.zerion.io
ZERION_API_KEY=

# Codex API key — get from https://codex.io
CODEX_API_KEY=

# Public app URL — used for share card links
# In development: http://localhost:3000
# In production: your deployed URL (e.g. https://sltp.matcha.xyz)
NEXT_PUBLIC_APP_URL=http://localhost:3000
